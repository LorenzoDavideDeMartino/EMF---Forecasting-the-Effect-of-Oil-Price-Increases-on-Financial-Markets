   "source": [
    "## 3g. MA(1) MLE with recursive innovations"
   ],
   "id": "3ab623d85f26"
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-31T10:28:53.701897800Z",
     "start_time": "2026-03-31T10:28:53.549348600Z"
    }
   },
   "source": [
    "def ma_innovations(u, theta):\n    T = len(u)\n    eps = np.zeros(T)\n    eps[0] = u[0]\n    for t in range(1, T):\n        eps[t] = u[t] - theta * eps[t - 1]\n    return eps"
   ],
   "id": "1b10d5669447",
   "outputs": [],
   "execution_count": 201
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-31T10:28:53.902142Z",
     "start_time": "2026-03-31T10:28:53.786022400Z"
    }
   },
   "source": [
    "def _loglik_contributions(params, y, X):\n    k = X.shape[1]\n    beta = params[:k]\n    theta = params[k]\n    u = y - X @ beta\n    eps = ma_innovations(u, theta)\n    sigma2 = np.mean(eps ** 2)\n    if sigma2 <= 0:\n        return np.full(len(y), -1e10)\n    return -0.5 * np.log(2 * np.pi * sigma2) - 0.5 * eps ** 2 / sigma2\n\ndef _negloglik_concentrated(params, y, X):\n    ll = _loglik_contributions(params, y, X)\n    return -np.sum(ll)"
   ],
   "id": "0129339a62f2",
   "outputs": [],
   "execution_count": 202
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-31T10:28:54.075965700Z",
     "start_time": "2026-03-31T10:28:53.955013Z"
    }
   },
   "source": [
    "def opg_standard_errors(params, y, X):\n    T = len(y)\n    n_params = len(params)\n    scores = np.zeros((T, n_params))\n    h = 1e-5\n    for j in range(n_params):\n        p_up = params.copy(); p_up[j] += h\n        p_dn = params.copy(); p_dn[j] -= h\n        scores[:, j] = (_loglik_contributions(p_up, y, X) - _loglik_contributions(p_dn, y, X)) / (2 * h)\n    OPG = scores.T @ scores\n    try:\n        se = np.sqrt(np.diag(np.linalg.inv(OPG)))\n    except np.linalg.LinAlgError:\n        se = np.full(n_params, np.nan)\n    return se"
   ],
